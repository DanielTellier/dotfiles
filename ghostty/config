# General
title = " "
window-padding-color = background
theme = "Monokai Pro"
font-family = "Geist Mono"
font-size = 16
font-feature = -calt, -liga, -dlig
cursor-style-blink=false
bell-features = no-title
copy-on-select = clipboard
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
confirm-close-surface = false

# Keybindings
keybind = ctrl+shift+m>n=new_window
keybind = ctrl+m>t=new_tab
keybind = ctrl+m>p=previous_tab
keybind = ctrl+m>n=next_tab
keybind = ctrl+m>comma=move_tab:-1
keybind = ctrl+m>period=move_tab:1
keybind = ctrl+m>1=goto_tab:1
keybind = ctrl+m>2=goto_tab:2
keybind = ctrl+m>3=goto_tab:3
keybind = ctrl+m>4=goto_tab:4
keybind = ctrl+m>5=goto_tab:5
keybind = ctrl+m>6=goto_tab:6
keybind = ctrl+m>7=goto_tab:7
keybind = ctrl+m>8=goto_tab:8
keybind = ctrl+m>9=goto_tab:9
keybind = ctrl+m>z=toggle_split_zoom
keybind = ctrl+m>e=equalize_splits
keybind = ctrl+m>s=new_split:auto
keybind = ctrl+m>v=new_split:right
keybind = ctrl+m>o=new_split:up
keybind = ctrl+m>l=goto_split:right
keybind = ctrl+m>h=goto_split:left
keybind = ctrl+m>k=goto_split:up
keybind = ctrl+m>j=goto_split:down
keybind = ctrl+m>q=close_surface
keybind = ctrl+m>c=close_window
keybind = ctrl+m>f=write_scrollback_file:paste
